---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    return [{ params: {} }];
}

const visaItems = await getCollection('visa');

const sortedItems = [...visaItems].sort((a, b) => {
    return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const countries = [...new Set(sortedItems.map(item => item.data.country))];
const categories = [...new Set(sortedItems.map(item => item.data.category))];

const countryNames: Record<string, string> = {
    canada: '🇨🇦 加拿大',
    usa: '🇺🇸 美国',
    australia: '🇦🇺 澳大利亚',
    japan: '🇯🇵 日本',
    schengen: '🇪🇺 申根区',
};

const countryColors: Record<string, string> = {
    canada: 'bg-red-100 text-red-700',
    usa: 'bg-blue-100 text-blue-700',
    australia: 'bg-yellow-100 text-yellow-700',
    japan: 'bg-pink-100 text-pink-700',
    schengen: 'bg-purple-100 text-purple-700',
};
---

<Layout title="签证政策 - 全球">
    <div class="page-container">
        <header class="page-header">
            <h1 class="header-title">签证政策</h1>
            <p class="header-subtitle">探索全球各国最新签证信息</p>
        </header>

        <div class="filter-bar">
            <div class="filter-group">
                <span class="filter-label">国家/地区</span>
                <div class="filter-options">
                    <button class="filter-chip active" data-filter="country" data-value="all">全部</button>
                    {countries.map(country => (
                        <button class="filter-chip" data-filter="country" data-value={country}>
                            {countryNames[country]}
                        </button>
                    ))}
                </div>
            </div>
            <div class="filter-divider"></div>
            <div class="filter-group">
                <span class="filter-label">签证类型</span>
                <div class="filter-options">
                    <button class="filter-chip active" data-filter="category" data-value="all">全部</button>
                    {categories.map(cat => (
                        <button class="filter-chip" data-filter="category" data-value={cat}>{cat}</button>
                    ))}
                </div>
            </div>
        </div>

        <div class="stats-bar">
            <span class="stats-text">共 <strong>{sortedItems.length}</strong> 条政策信息</span>
        </div>

        <div class="cards-grid">
            {sortedItems.map(item => (
                <article class="visa-card" data-country={item.data.country} data-category={item.data.category}>
                    <a href={`/visa/${item.id}`} class="card-link">
                        <div class="card-badge">
                            <span class={`country-tag ${countryColors[item.data.country] || 'bg-gray-100 text-gray-700'}`}>
                                {countryNames[item.data.country] || item.data.country}
                            </span>
                            {item.data.language && (
                                <span class={`language-tag ${
                                    item.data.language === 'zh' ? 'bg-green-100 text-green-700' :
                                    item.data.language === 'ja' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-700'
                                }`}>
                                    {item.data.language === 'zh' ? '中文' : item.data.language === 'ja' ? '日本語' : 'EN'}
                                </span>
                            )}
                        </div>
                        <h2 class="card-title">{item.data.title}</h2>
                        {item.data.summary && (
                            <p class="card-summary">{item.data.summary}</p>
                        )}
                        <div class="card-meta">
                            <span class="category-tag">{item.data.category}</span>
                            <span class="date-tag">
                                {typeof item.data.date === 'object'
                                    ? item.data.date.toISOString().split('T')[0]
                                    : item.data.date}
                            </span>
                        </div>
                    </a>
                </article>
            ))}
        </div>

        {sortedItems.length === 0 && (
            <div class="empty-state">
                <div class="empty-icon">🔍</div>
                <p class="empty-title">暂无签证政策信息</p>
                <p class="empty-subtitle">请稍后再试，或尝试调整筛选条件</p>
                <button class="empty-button" onclick="window.location.reload()">刷新页面</button>
            </div>
        )}
    </div>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterChips = document.querySelectorAll('.filter-chip');
        const cards = document.querySelectorAll('.visa-card');

        let activeCountry = 'all';
        let activeCategory = 'all';

        function applyFilters() {
            let visibleCount = 0;
            cards.forEach(card => {
                const countryMatch = activeCountry === 'all' || card.dataset.country === activeCountry;
                const categoryMatch = activeCategory === 'all' || card.dataset.category === activeCategory;
                card.style.display = countryMatch && categoryMatch ? 'block' : 'none';
                if (countryMatch && categoryMatch) visibleCount++;
            });
            
            const statsEl = document.querySelector('.stats-text');
            if (statsEl) {
                statsEl.innerHTML = `共 <strong>${cards.length}</strong> 条政策信息，当前显示 <strong>${visibleCount}</strong> 条`;
            }
        }

        function updateHash() {
            const params = new URLSearchParams();
            if (activeCountry !== 'all') params.set('country', activeCountry);
            if (activeCategory !== 'all') params.set('category', activeCategory);
            const hash = params.toString();
            window.location.hash = hash ? `#${hash}` : '';
        }

        function setFilter(filterType, value) {
            document.querySelectorAll(`.filter-chip[data-filter="${filterType}"]`)
                .forEach(b => b.classList.remove('active'));
            const targetChip = document.querySelector(`.filter-chip[data-filter="${filterType}"][data-value="${value}"]`);
            if (targetChip) targetChip.classList.add('active');

            if (filterType === 'country') {
                activeCountry = value || 'all';
            } else {
                activeCategory = value || 'all';
            }

            applyFilters();
            updateHash();
        }

        filterChips.forEach(chip => {
            chip.addEventListener('click', () => {
                const filterType = chip.dataset.filter;
                const value = chip.dataset.value;
                setFilter(filterType, value);
            });
        });

        function parseHash() {
            const hash = window.location.hash.slice(1);
            if (!hash) return;
            try {
                const params = new URLSearchParams(hash);
                const country = params.get('country');
                const category = params.get('category');
                if (country) {
                    activeCountry = country;
                    const countryChip = document.querySelector(`.filter-chip[data-filter="country"][data-value="${country}"]`);
                    if (countryChip) countryChip.classList.add('active');
                    document.querySelector('.filter-chip[data-filter="country"][data-value="all"]')?.classList.remove('active');
                }
                if (category) {
                    activeCategory = category;
                    const categoryChip = document.querySelector(`.filter-chip[data-filter="category"][data-value="${category}"]`);
                    if (categoryChip) categoryChip.classList.add('active');
                    document.querySelector('.filter-chip[data-filter="category"][data-value="all"]')?.classList.remove('active');
                }
                applyFilters();
            } catch (e) {
                console.error('解析 hash 参数失败:', e);
            }
        }

        parseHash();
        window.addEventListener('hashchange', parseHash);
    });
</script>

<style>
    :root {
        --primary-color: #FF385C;
        --primary-hover: #E61E4D;
        --text-primary: #222222;
        --text-secondary: #6B6B6B;
        --text-muted: #999999;
        --bg-primary: #FFFFFF;
        --bg-secondary: #F7F7F7;
        --border-color: #EBEBEB;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.08);
        --shadow-md: 0 2px 8px rgba(0,0,0,0.1);
        --shadow-lg: 0 4px 16px rgba(0,0,0,0.12);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
    }

    .page-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 24px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: var(--bg-secondary);
        min-height: calc(100vh - 80px);
    }

    .page-header {
        margin-bottom: 32px;
        text-align: center;
    }

    .header-title {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 8px 0;
    }

    .header-subtitle {
        font-size: 16px;
        color: var(--text-secondary);
        margin: 0;
    }

    .filter-bar {
        background: var(--bg-primary);
        border-radius: var(--radius-lg);
        padding: 16px 24px;
        margin-bottom: 24px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 24px;
        box-shadow: var(--shadow-sm);
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
        min-width: 200px;
    }

    .filter-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .filter-options {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .filter-chip {
        padding: 8px 16px;
        border: 1px solid var(--border-color);
        border-radius: 20px;
        background: var(--bg-primary);
        font-size: 14px;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .filter-chip:hover {
        border-color: var(--text-primary);
        color: var(--text-primary);
    }

    .filter-chip.active {
        background: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
    }

    .filter-chip.active:hover {
        background: var(--primary-hover);
        border-color: var(--primary-hover);
    }

    .filter-divider {
        width: 1px;
        height: 40px;
        background: var(--border-color);
    }

    .stats-bar {
        margin-bottom: 24px;
    }

    .stats-text {
        font-size: 14px;
        color: var(--text-secondary);
    }

    .stats-text strong {
        color: var(--text-primary);
        font-weight: 600;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    .visa-card {
        background: var(--bg-primary);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .visa-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
    }

    .card-link {
        display: block;
        padding: 20px;
        text-decoration: none;
        color: inherit;
    }

    .card-badge {
        display: flex;
        gap: 8px;
        margin-bottom: 12px;
    }

    .country-tag,
    .language-tag {
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
    }

    .card-title {
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 8px 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-summary {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.5;
        margin: 0 0 12px 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 12px;
        border-top: 1px solid var(--border-color);
    }

    .category-tag {
        padding: 4px 12px;
        background: var(--primary-color);
        color: white;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
    }

    .date-tag {
        font-size: 12px;
        color: var(--text-muted);
    }

    .empty-state {
        text-align: center;
        padding: 80px 24px;
        background: var(--bg-primary);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
    }

    .empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .empty-title {
        font-size: 20px;
        font-weight: 600;
        color: var(--text-primary);
        margin: 0 0 8px 0;
    }

    .empty-subtitle {
        font-size: 14px;
        color: var(--text-secondary);
        margin: 0 0 24px 0;
    }

    .empty-button {
        padding: 12px 24px;
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: var(--radius-md);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .empty-button:hover {
        background: var(--primary-hover);
    }

    @media (max-width: 768px) {
        .page-container {
            padding: 16px;
        }

        .header-title {
            font-size: 24px;
        }

        .filter-bar {
            padding: 16px;
        }

        .filter-divider {
            display: none;
        }

        .cards-grid {
            grid-template-columns: 1fr;
        }

        .card-link {
            padding: 16px;
        }
    }
</style>